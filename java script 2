import * as THREE from 'three';

// Socket connection
const socket = io(window.location.origin);

// Game state
let scene, camera, renderer;
let playerModel;
let otherPlayers = new Map();
let buildings = [];
let interactiveZones = [];
let currentPlayer = null;
let cityZones = null;
let keys = { w: false, s: false, a: false, d: false };
let pitch = 0, yaw = -Math.PI / 3;
let pointerLock = false;
let currentLookTarget = null;
let animationId = null;

// UI Elements
const loadingScreen = document.getElementById('loading-screen');
const moneySpan = document.getElementById('money');
const playerNameSpan = document.getElementById('player-name');
const jobNameSpan = document.getElementById('job-name');
const energySpan = document.getElementById('energy');
const happinessSpan = document.getElementById('happiness');
const promptText = document.getElementById('prompt-text');
const actionButtons = document.getElementById('action-buttons');
const infoWindow = document.getElementById('info-window');
const infoTitle = document.getElementById('info-title');
const infoContent = document.getElementById('info-content');
const notification = document.getElementById('notification');

// Initialize Three.js
function init() {
    scene = new THREE.Scene();
    scene.background = new THREE.Color(0x87CEEB);
    scene.fog = new THREE.FogExp2(0x87CEEB, 0.008);
    
    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 1.6, 5);
    camera.rotation.order = 'YXZ';
    
    renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.shadowMap.enabled = true;
    document.body.appendChild(renderer.domElement);
    
    // Add crosshair
    const crosshair = document.createElement('div');
    crosshair.className = 'crosshair';
    document.body.appendChild(crosshair);
    
    // Lighting
    const ambientLight = new THREE.AmbientLight(0x404060);
    scene.add(ambientLight);
    
    const sunLight = new THREE.DirectionalLight(0xfff5e6, 1.2);
    sunLight.position.set(20, 30, 10);
    sunLight.castShadow = true;
    sunLight.shadow.mapSize.width = 1024;
    sunLight.shadow.mapSize.height = 1024;
    scene.add(sunLight);
    
    const fillLight = new THREE.PointLight(0x4466cc, 0.4);
    fillLight.position.set(0, 10, 0);
    scene.add(fillLight);
    
    // Ground
    const groundMat = new THREE.MeshStandardMaterial({ color: 0x8B7355, roughness: 0.8 });
    const ground = new THREE.Mesh(new THREE.PlaneGeometry(200, 200), groundMat);
    ground.rotation.x = -Math.PI / 2;
    ground.position.y = -0.1;
    ground.receiveShadow = true;
    scene.add(ground);
    
    // Grid helper
    const grid = new THREE.GridHelper(200, 40, 0x88aaff, 0x4466aa);
    grid.position.y = 0;
    scene.add(grid);
    
    // Setup controls
    setupControls();
    
    // Start animation
    animate();
}

function setupControls() {
    document.addEventListener('click', () => {
        renderer.domElement.requestPointerLock();
    });
    
    document.addEventListener('pointerlockchange', () => {
        pointerLock = document.pointerLockElement === renderer.domElement;
        if (pointerLock) {
            document.addEventListener('mousemove', onMouseMove);
            loadingScreen.style.display = 'none';
        } else {
            document.removeEventListener('mousemove', onMouseMove);
        }
    });
    
    window.addEventListener('keydown', (e) => {
        switch(e.code) {
            case 'KeyW': keys.w = true; break;
            case 'KeyS': keys.s = true; break;
            case 'KeyA': keys.a = true; break;
            case 'KeyD': keys.d = true; break;
            case 'KeyE': interact(); break;
        }
    });
    
    window.addEventListener('keyup', (e) => {
        switch(e.code) {
            case 'KeyW': keys.w = false; break;
            case 'KeyS': keys.s = false; break;
            case 'KeyA': keys.a = false; break;
            case 'KeyD': keys.d = false; break;
        }
    });
}

function onMouseMove(e) {
    if (!pointerLock) return;
    yaw -= e.movementX * 0.002;
    pitch -= e.movementY * 0.002;
    pitch = Math.max(-Math.PI / 2.2, Math.min(Math.PI / 2.2, pitch));
    camera.rotation.y = yaw;
    camera.rotation.x = pitch;
}

function updateMovement() {
    if (!pointerLock) return;
    
    const speed = 5.0;
    const delta = 1/60;
    const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
    const right = new THREE.Vector3(1, 0, 0).applyQuaternion(camera.quaternion);
    forward.y = 0;
    forward.normalize();
    right.y = 0;
    right.normalize();
    
    let move = new THREE.Vector3();
    if (keys.w) move.add(forward);
    if (keys.s) move.sub(forward);
    if (keys.d) move.add(right);
    if (keys.a) move.sub(right);
    move.multiplyScalar(speed * delta);
    
    const newPos = camera.position.clone().add(move);
    
    // Simple collision
    let collide = false;
    for (let building of buildings) {
        const bounds = building.userData.bounds;
        if (bounds && newPos.x > bounds.minX && newPos.x < bounds.maxX && 
            newPos.z > bounds.minZ && newPos.z < bounds.maxZ) {
            collide = true;
            break;
        }
    }
    
    if (!collide && Math.abs(newPos.x) < 80 && Math.abs(newPos.z) < 80) {
        camera.position.copy(newPos);
    }
    
    // Send position to server
    socket.emit('player-move', {
        position: { x: camera.position.x, y: camera.position.y, z: camera.position.z },
        rotation: { yaw: yaw, pitch: pitch }
    });
}

function buildCity(zones) {
    const colors = {
        industrial: 0x8B7D6B,
        residential: 0x7CB342,
        business: 0x42A5F5,
        downtown: 0xFFD700
    };
    
    for (const [zoneName, zone] of Object.entries(zones)) {
        // Build properties
        for (const prop of zone.properties) {
            const geometry = new THREE.BoxGeometry(2.5, 3, 2.5);
            const material = new THREE.MeshStandardMaterial({ color: colors[zoneName], roughness: 0.3 });
            const building = new THREE.Mesh(geometry, material);
            building.position.set(prop.position.x, 1.5, prop.position.z);
            building.castShadow = true;
            building.receiveShadow = true;
            building.userData = {
                type: 'property',
                data: prop,
                zone: zoneName,
                bounds: {
                    minX: prop.position.x - 1.5,
                    maxX: prop.position.x + 1.5,
                    minZ: prop.position.z - 1.5,
                    maxZ: prop.position.z + 1.5
                }
            };
            scene.add(building);
            buildings.push(building);
            interactiveZones.push({ mesh: building, data: prop, type: 'property', zone: zoneName });
        }
        
        // Build businesses
        for (const biz of zone.businesses) {
            const geometry = new THREE.BoxGeometry(2.8, 2.5, 2.8);
            const material = new THREE.MeshStandardMaterial({ color: colors[zoneName], emissive: 0x331100 });
            const business = new THREE.Mesh(geometry, material);
            business.position.set(biz.position.x, 1.5, biz.position.z);
            business.castShadow = true;
            business.userData = {
                type: 'business',
                data: biz,
                zone: zoneName,
                bounds: {
                    minX: biz.position.x - 1.6,
                    maxX: biz.position.x + 1.6,
                    minZ: biz.position.z - 1.6,
                    maxZ: biz.position.z + 1.6
                }
            };
            scene.add(business);
            buildings.push(business);
            interactiveZones.push({ mesh: business, data: biz, type: 'business', zone: zoneName });
        }
    }
}

function createPlayerModel() {
    const group = new THREE.Group();
    const bodyGeo = new THREE.BoxGeometry(0.6, 1.2, 0.6);
    const bodyMat = new THREE.MeshStandardMaterial({ color: 0x44aa88 });
    const body = new THREE.Mesh(bodyGeo, bodyMat);
    body.position.y = 0.6;
    body.castShadow = true;
    group.add(body);
    
    const headGeo = new THREE.SphereGeometry(0.4);
    const headMat = new THREE.MeshStandardMaterial({ color: 0xffccaa });
    const head = new THREE.Mesh(headGeo, headMat);
    head.position.y = 1.2;
    head.castShadow = true;
    group.add(head);
    
    return group;
}

function addOtherPlayer(id, username, position, rotation) {
    const playerGroup = createPlayerModel();
    playerGroup.position.set(position.x, position.y, position.z);
    scene.add(playerGroup);
    
    otherPlayers.set(id, {
        mesh: playerGroup,
        username: username,
        lastPosition: position
    });
    
    // Add name tag
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = 256;
    canvas.height = 64;
    ctx.fillStyle = '#000000aa';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = 'white';
    ctx.font = '16px Arial';
    ctx.fillText(username, 10, 30);
    const texture = new THREE.CanvasTexture(canvas);
    const spriteMat = new THREE.SpriteMaterial({ map: texture });
    const sprite = new THREE.Sprite(spriteMat);
    sprite.scale.set(1.5, 0.5, 1);
    sprite.position.y = 1.8;
    playerGroup.add(sprite);
}

function raycastInteraction() {
    const raycaster = new THREE.Raycaster(camera.position, new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion));
    const intersects = raycaster.intersectObjects(buildings);
    
    if (intersects.length > 0 && intersects[0].distance < 4) {
        return intersects[0].object.userData;
    }
    return null;
}

function updatePrompt() {
    const target = raycastInteraction();
    currentLookTarget = target;
    
    if (target) {
        if (target.type === 'property') {
            const owned = currentPlayer?.properties?.includes(target.data.id);
            if (owned) {
                promptText.innerHTML = `🏠 ${target.data.name} (OWNED) | Rent: $${target.data.rent}/30s`;
                actionButtons.innerHTML = '';
            } else {
                promptText.innerHTML = `💰 ${target.data.name} - $${target.data.price}`;
                actionButtons.innerHTML = `<button onclick="buyProperty('${target.data.id}')">Buy Property</button>`;
            }
        } else if (target.type === 'business') {
            const owned = currentPlayer?.businesses?.includes(target.data.id);
            if (owned) {
                promptText.innerHTML = `🏪 ${target.data.name} (OWNED) | Profit: $${target.data.profit}/30s`;
                actionButtons.innerHTML = '';
            } else {
                promptText.innerHTML = `💼 ${target.data.name} - $${target.data.price}`;
                actionButtons.innerHTML = `<button onclick="buyBusiness('${target.data.id}')">Start Business</button>`;
            }
        }
    } else {
        promptText.innerHTML = "🔍 Look at a building to interact";
        actionButtons.innerHTML = '';
    }
}

function interact() {
    if (currentLookTarget) {
        if (currentLookTarget.type === 'property') {
            buyProperty(currentLookTarget.data.id);
        } else if (currentLookTarget.type === 'business') {
            buyBusiness(currentLookTarget.data.id);
        }
    } else {
        // Work at current job
        socket.emit('work-job');
    }
}

function showNotification(msg, isError = false) {
    notification.textContent = msg;
    notification.style.display = 'block';
    notification.style.borderLeftColor = isError ? '#ff8888' : '#88ffaa';
    setTimeout(() => {
        notification.style.display = 'none';
    }, 3000);
}

function buyProperty(propertyId) {
    socket.emit('buy-property', propertyId);
}

function buyBusiness(businessId) {
    socket.emit('buy-business', businessId);
}

function showPropertiesMenu() {
    infoTitle.textContent = '🏢 Available Properties';
    infoContent.innerHTML = '';
    
    for (const [zoneName, zone] of Object.entries(cityZones)) {
        const zoneDiv = document.createElement('div');
        zoneDiv.style.marginBottom = '20px';
        zoneDiv.innerHTML = `<h3>${zone.name}</h3>`;
        
        for (const prop of zone.properties) {
            const owned = currentPlayer?.properties?.includes(prop.id);
            const itemDiv = document.createElement('div');
            itemDiv.className = 'property-item';
            itemDiv.innerHTML = `
                <div>
                    <div class="property-name">${prop.name}</div>
                    <div class="property-price">💰 $${prop.price} | 📈 +$${prop.rent}/30s</div>
                </div>
                ${!owned ? `<button class="buy-btn" onclick="buyProperty('${prop.id}')">Buy</button>` : '<span class="owned-badge">OWNED</span>'}
            `;
            zoneDiv.appendChild(itemDiv);
        }
        infoContent.appendChild(zoneDiv);
    }
    
    infoWindow.style.display = 'flex';
}

function showBusinessesMenu() {
    infoTitle.textContent = '🏪 Available Businesses';
    infoContent.innerHTML = '';
    
    for (const [zoneName, zone] of Object.entries(cityZones)) {
        const zoneDiv = document.createElement('div');
        zoneDiv.style.marginBottom = '20px';
        zoneDiv.innerHTML = `<h3>${zone.name}</h3>`;
        
        for (const biz of zone.businesses) {
            const owned = currentPlayer?.businesses?.includes(biz.id);
            const itemDiv = document.createElement('div');
            itemDiv.className = 'business-item';
            itemDiv.innerHTML = `
                <div>
                    <div class="business-name">${biz.name}</div>
                    <div class="business-price">💰 $${biz.price} | 📈 +$${biz.profit}/30s</div>
                </div>
                ${!owned ? `<button class="buy-btn" onclick="buyBusiness('${biz.id}')">Start</button>` : '<span class="owned-badge">OWNED</span>'}
            `;
            zoneDiv.appendChild(itemDiv);
        }
        infoContent.appendChild(zoneDiv);
    }
    
    infoWindow.style.display = 'flex';
}

function showJobsMenu() {
    infoTitle.textContent = '💼 Available Jobs';
    infoContent.innerHTML = '';
    
    for (const [zoneName, zone] of Object.entries(cityZones)) {
        const zoneDiv = document.createElement('div');
        zoneDiv.style.marginBottom = '20px';
        zoneDiv.innerHTML = `<h3>${zone.name}</h3>`;
        
        for (const job of zone.jobs) {
            const isCurrent = currentPlayer?.job?.id === job.id;
            const affordable = currentPlayer?.money >= job.requirement;
            const itemDiv = document.createElement('div');
            itemDiv.className = 'job-item';
            itemDiv.innerHTML = `
                <div>
                    <div class="job-name">${job.name} ${isCurrent ? '(Current)' : ''}</div>
                    <div class="job-pay">💰 $${job.pay}/work | Need $${job.requirement}</div>
                </div>
                ${!isCurrent && affordable ? `<button class="switch-btn" onclick="changeJob('${job.id}')">Switch</button>` : ''}
            `;
            zoneDiv.appendChild(itemDiv);
        }
        infoContent.appendChild(zoneDiv);
    }
    
    infoWindow.style.display = 'flex';
}

function showPlayersMenu() {
    infoTitle.textContent = '👥 Online Players';
    infoContent.innerHTML = '';
    
    for (const [id, player] of otherPlayers) {
        const itemDiv = document.createElement('div');
        itemDiv.className = 'player-item';
        itemDiv.innerHTML = `
            <div>
                <div>${player.username}</div>
                <div style="font-size: 11px; color: #8a9bcb;">Exploring the city</div>
            </div>
        `;
        infoContent.appendChild(itemDiv);
    }
    
    if (otherPlayers.size === 0) {
        infoContent.innerHTML = '<div style="text-align: center;">No other players online</div>';
    }
    
    infoWindow.style.display = 'flex';
}

function changeJob(jobId) {
    socket.emit('change-job', jobId);
}

// Socket event handlers
socket.on('game-init', (data) => {
    currentPlayer = data.player;
    cityZones = data.zones;
    
    moneySpan.textContent = currentPlayer.money;
    playerNameSpan.textContent = currentPlayer.username;
    jobNameSpan.textContent = currentPlayer.job?.name || 'No Job';
    energySpan.textContent = currentPlayer.stats.energy;
    happinessSpan.textContent = currentPlayer.stats.happiness;
    
    camera.position.set(currentPlayer.position.x, currentPlayer.position.y, currentPlayer.position.z);
    
    buildCity(cityZones);
    
    // Add existing players
    data.players.forEach(p => {
        if (p.id !== socket.id) {
            addOtherPlayer(p.id, p.username, p.position, p.rotation);
        }
    });
});

socket.on('player-joined', (data) => {
    if (data.id !== socket.id) {
        addOtherPlayer(data.id, data.username, data.position, data.rotation);
        showNotification(`${data.username} joined the city`);
    }
});

socket.on('player-moved', (data) => {
    const player = otherPlayers.get(data.id);
    if (player) {
        player.mesh.position.set(data.position.x, data.position.y, data.position.z);
    }
});

socket.on('player-left', (id) => {
    const player = otherPlayers.get(id);
    if (player) {
        scene.remove(player.mesh);
        otherPlayers.delete(id);
    }
});

socket.on('work-result', (result) => {
    if (result.success) {
        moneySpan.textContent = result.newMoney;
        showNotification(`💼 Worked! +$${result.amount}`);
    } else {
        showNotification(result.message, true);
    }
});

socket.on('purchase-result', (result) => {
    if (result.success) {
        moneySpan.textContent = result.newMoney;
        showNotification(`🎉 Purchased ${result.property?.name || result.business?.name}!`);
        if (currentPlayer) {
            if (result.property) currentPlayer.properties.push(result.property.id);
            if (result.business) currentPlayer.businesses.push(result.business.id);
        }
    } else {
        showNotification(result.message, true);
    }
});

socket.on('job-change-result', (result) => {
    if (result.success) {
        currentPlayer.job = result.job;
        jobNameSpan.textContent = result.job.name;
        showNotification(`📋 Now working as ${result.job.name} ($${result.job.pay}/work)`);
    } else {
        showNotification(result.message, true);
    }
});

socket.on('player-update', (data) => {
    if (currentPlayer) {
        if (data.money) currentPlayer.money = data.money;
        if (data.job) currentPlayer.job = data.job;
        if (data.properties) currentPlayer.properties = data.properties;
        if (data.businesses) currentPlayer.businesses = data.businesses;
        moneySpan.textContent = currentPlayer.money;
        jobNameSpan.textContent = currentPlayer.job?.name || 'No Job';
    }
});

// Menu handlers
document.querySelectorAll('.menu-tab').forEach(btn => {
    btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        if (tab === 'properties') showPropertiesMenu();
        if (tab === 'businesses') showBusinessesMenu();
        if (tab === 'jobs') showJobsMenu();
        if (tab === 'players') showPlayersMenu();
    });
});

document.getElementById('close-info').addEventListener('click', () => {
    infoWindow.style.display = 'none';
});

// Animation loop
function animate() {
    updateMovement();
    updatePrompt();
    renderer.render(scene, camera);
    requestAnimationFrame(animate);
}

// Expose functions to global for HTML buttons
window.buyProperty = buyProperty;
window.buyBusiness = buyBusiness;
window.changeJob = changeJob;

// Initialize
init();
